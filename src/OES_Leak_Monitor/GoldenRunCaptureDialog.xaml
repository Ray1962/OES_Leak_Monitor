<Window x:Class="OES_Leak_Monitor.GoldenRunCaptureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capture Golden Run"
        SizeToContent="Height" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock TextWrapping="Wrap" Foreground="#444" Margin="0,0,0,12"
                   Text="A Golden Run records the leak-free baseline ratios. Run a known-good process, then capture."/>

        <TextBlock Text="Recipe / baseline name" FontWeight="SemiBold"/>
        <TextBox x:Name="NameBox" Margin="0,4,0,12" Padding="4,3"/>

        <TextBlock x:Name="DurationText" Foreground="#444" Margin="0,0,0,12"/>

        <CheckBox x:Name="ConfirmCheck" Click="Confirm_Click" Margin="0,0,0,16"
                  Content="I confirm the process is currently running leak-free."/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="Start Capture" Click="Ok_Click"
                    Padding="14,6" MinWidth="120" Margin="0,0,8,0" IsEnabled="False"/>
            <Button Content="Cancel" Click="Cancel_Click" IsCancel="True"
                    Padding="14,6" MinWidth="90"/>
        </StackPanel>
    </StackPanel>
</Window>
