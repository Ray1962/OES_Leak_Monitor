<UserControl x:Class="OES_Leak_Monitor.RatioReviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#F4F6FA">

    <UserControl.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin"  Value="0,0,4,0"/>
            <Setter Property="MinWidth" Value="84"/>
        </Style>
        <Style x:Key="ModeButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="MinWidth" Value="110"/>
        </Style>
        <Style x:Key="ActiveModeBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Ratio Review"
                   FontSize="16" FontWeight="Bold" Foreground="#1F3A66"
                   Margin="6,4,6,8"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#EEF2F7" BorderBrush="#CCC" BorderThickness="1"
                CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#444"/>
                    <TextBox Width="150" Padding="4,2"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filter ratio files by date / time / filename substring."/>
                </StackPanel>

                <WrapPanel VerticalAlignment="Center">
                    <Button Content="Refresh" Style="{StaticResource ToolbarButton}"
                            Command="{Binding RefreshCommand}"
                            ToolTip="Re-scan the base directory for ratio CSV files."/>
                    <Button Content="Open Base" Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenBaseFolderCommand}"
                            ToolTip="Open the logger's base directory in Windows Explorer."/>
                    <Button Content="Open Folder" Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenFolderCommand}"
                            ToolTip="Open the selected file's folder."/>
                    <Button Content="Open File" Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenFileCommand}"
                            ToolTip="Open the selected ratio CSV in its default application."/>

                    <Rectangle Width="1" Margin="6,2" Fill="#CCC"/>
                    <TextBlock Text="View:" VerticalAlignment="Center" Margin="2,0,4,0" Foreground="#444"/>

                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource ActiveModeBorder}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPercentMode}" Value="True">
                                        <Setter Property="BorderBrush" Value="#1F7A3A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Content="% of baseline" Style="{StaticResource ModeButton}"
                                Command="{Binding ShowPercentCommand}"
                                ToolTip="Plot each ratio as a percentage of its Golden Run baseline."/>
                    </Border>
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource ActiveModeBorder}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRawMode}" Value="True">
                                        <Setter Property="BorderBrush" Value="#1F7A3A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Content="Raw ratio" Style="{StaticResource ModeButton}"
                                Command="{Binding ShowRawCommand}"
                                ToolTip="Plot the raw (un-normalised) ratio values."/>
                    </Border>

                    <Rectangle Width="1" Margin="6,2" Fill="#CCC"/>
                    <Button Content="Zoom All" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ZoomAllCommand}"
                            ToolTip="Reset the chart to fit all data."/>
                    <Button Content="Save PNG" Style="{StaticResource ToolbarButton}"
                            Command="{Binding SavePngCommand}"
                            ToolTip="Save the trend chart as a PNG file."/>
                    <Button Content="Copy Image" Style="{StaticResource ToolbarButton}"
                            Command="{Binding CopyImageCommand}"
                            ToolTip="Copy the trend chart to the clipboard."/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- File list | trend chart -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
                <DataGrid ItemsSource="{Binding Files}"
                          SelectedItem="{Binding SelectedFile}"
                          SelectionMode="Single"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#FAFAFA"
                          EnableRowVirtualization="True"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding DateText}"     Width="90"/>
                        <DataGridTextColumn Header="Time" Binding="{Binding TimeText}"     Width="80"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding FileSizeText}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="#DDD"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"/>

            <Border Grid.Column="2" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
                <oxy:PlotView Model="{Binding PlotModel}"
                              Controller="{Binding PlotController}"
                              Background="White">
                    <oxy:PlotView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Zoom All"   Command="{Binding ZoomAllCommand}" InputGestureText="A"/>
                            <Separator/>
                            <MenuItem Header="Save PNG…"  Command="{Binding SavePngCommand}"/>
                            <MenuItem Header="Copy Image" Command="{Binding CopyImageCommand}"/>
                            <Separator/>
                            <MenuItem Header="Open File"          Command="{Binding OpenFileCommand}"/>
                            <MenuItem Header="Open Session Folder" Command="{Binding OpenFolderCommand}"/>
                        </ContextMenu>
                    </oxy:PlotView.ContextMenu>
                </oxy:PlotView>
            </Border>
        </Grid>

        <!-- Status / meta strip -->
        <Border Grid.Row="3" Background="#EEF2F7" BorderBrush="#CCC" BorderThickness="1"
                CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status:" FontWeight="Bold" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="#444"/>
                    <TextBlock Text="  ·  Base:" FontWeight="Bold" Margin="16,0,6,0"/>
                    <TextBlock Text="{Binding EffectiveBaseDirectory}"
                               FontFamily="Consolas, monospace"
                               ToolTip="{Binding EffectiveBaseDirectory}"/>
                </StackPanel>
                <TextBlock Text="{Binding MetaText}" Foreground="#666"
                           FontFamily="Consolas, monospace" FontSize="11"
                           TextWrapping="NoWrap" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
