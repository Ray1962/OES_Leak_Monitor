<UserControl x:Class="OES_Leak_Monitor.WavelengthCorrectionPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="820"
             Background="#F4F6FA">

    <UserControl.Resources>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="4,0,4,4"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Wavelength Calibration"
                   FontSize="16" FontWeight="Bold" Foreground="#1F3A66"
                   Margin="6,4,6,8"/>

        <!-- Apply-on-restart notice -->
        <Border Grid.Row="1" Background="#FFF6E0" BorderBrush="#E8C870" BorderThickness="1"
                CornerRadius="4" Padding="10,7" Margin="0,0,0,8">
            <TextBlock TextWrapping="Wrap" Foreground="#7A5A10">
                Each row shifts one catalog <Run FontWeight="Bold">(element, wavelength)</Run> line by
                a drift offset, and applies to <Run FontWeight="Bold">every</Run> ratio that uses that
                line. Edits are staged: after <Run FontWeight="Bold">Save</Run> they are written to
                <Run FontWeight="Bold">settings.json</Run> but take effect only after you
                <Run FontWeight="Bold">Stop</Run> OES acquisition and press
                <Run FontWeight="Bold">Start OES</Run> again.
            </TextBlock>
        </Border>

        <!-- Correction table -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
            <DockPanel>
                <!-- Add / Remove footer -->
                <Border DockPanel.Dock="Bottom" Background="#FAFAFA"
                        BorderBrush="#EEE" BorderThickness="0,1,0,0" Padding="6">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Add" Command="{Binding AddCommand}"
                                Padding="10,4" MinWidth="64" Margin="0,0,4,0"
                                ToolTip="Add a wavelength correction for a catalog line."/>
                        <Button Content="Remove" Command="{Binding RemoveCommand}"
                                Padding="10,4" MinWidth="64" Margin="0,0,12,0"
                                ToolTip="Remove the selected correction."/>
                        <TextBlock Text="{Binding CountText}" Foreground="#888"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Column headers -->
                <Grid DockPanel.Dock="Top" Margin="8,8,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Element" Style="{StaticResource ColHeader}"/>
                    <TextBlock Grid.Column="2" Text="Wavelength (nm)" Style="{StaticResource ColHeader}"/>
                    <TextBlock Grid.Column="4" Text="Correction (nm)" Style="{StaticResource ColHeader}"/>
                </Grid>

                <ListBox ItemsSource="{Binding Corrections}"
                         SelectedItem="{Binding SelectedCorrection}"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding SpeciesOptions}"
                                          SelectedItem="{Binding Species}"
                                          IsSynchronizedWithCurrentItem="False"
                                          MaxDropDownHeight="360"
                                          ToolTip="Catalog element / species this correction applies to."/>

                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding WavelengthOptions}"
                                          SelectedItem="{Binding Wavelength}"
                                          IsSynchronizedWithCurrentItem="False"
                                          MaxDropDownHeight="360"
                                          ToolTip="Catalog wavelength of the line, nm.">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat={}{0:0.###}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBox Grid.Column="4"
                                         Text="{Binding OffsetNm, UpdateSourceTrigger=LostFocus}"
                                         Padding="4,2"
                                         ToolTip="Additive drift offset, nm. Effective center = catalog wavelength + this (±5 nm max)."/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <!-- Empty-state hint -->
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Corrections.Count}" Value="0">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="No corrections — every line uses its catalog wavelength.  Press Add to correct one."
                                                               Foreground="#AAA" Margin="14"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Bottom bar -->
        <Border Grid.Row="3" Background="#EEF2F7" BorderBrush="#CCC" BorderThickness="1"
                CornerRadius="4" Padding="10,8" Margin="0,8,0,0">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Left" Content="Save"
                        Command="{Binding SaveCommand}"
                        Padding="16,6" MinWidth="110" Margin="0,0,8,0"
                        ToolTip="Persist the wavelength corrections to settings.json (Engineer+)."/>
                <Button DockPanel.Dock="Left" Content="Revert"
                        Command="{Binding RevertCommand}"
                        Padding="16,6" MinWidth="90" Margin="0,0,16,0"
                        ToolTip="Discard unsaved edits and reload the saved corrections."/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="#444" TextWrapping="Wrap"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
