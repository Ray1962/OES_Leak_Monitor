<UserControl x:Class="OES_Leak_Monitor.LeakMonitorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel Background="#F4F6FA">

        <!-- Composite status banner -->
        <Border DockPanel.Dock="Top" Background="{Binding OverallBrush}" Padding="14,10">
            <StackPanel>
                <TextBlock Text="{Binding OverallText}" Foreground="White"
                           FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="{Binding TestModeNote}" Foreground="#FFEFC8"
                           FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Toolbar: Golden Run + actions -->
        <Border DockPanel.Dock="Top" Background="#FAFAFA"
                BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Baseline:" VerticalAlignment="Center"
                           FontWeight="Bold" Margin="0,0,6,0"/>
                <ComboBox MinWidth="150" VerticalAlignment="Center"
                          ItemsSource="{Binding GoldenRunNames}"
                          SelectedItem="{Binding SelectedGoldenRun}"
                          ToolTip="Active leak-free Golden Run used as the baseline."/>
                <Button Content="Capture Golden Run"
                        Command="{Binding CaptureGoldenRunCommand}"
                        Padding="12,4" Margin="12,0,4,0"
                        ToolTip="Average the ratios over a known leak-free run to set the baseline (Engineer+)."/>
                <Button Content="Cancel"
                        Command="{Binding CancelCaptureCommand}"
                        Padding="12,4" Margin="0,0,12,0"
                        Visibility="{Binding CaptureActive, Converter={StaticResource BoolToVis}}"/>
                <ProgressBar Width="120" Height="16" VerticalAlignment="Center"
                             Minimum="0" Maximum="100"
                             Value="{Binding CaptureProgressPercent, Mode=OneWay}"
                             Visibility="{Binding CaptureActive, Converter={StaticResource BoolToVis}}"/>
                <Button Content="Acknowledge Alarm"
                        Command="{Binding AcknowledgeCommand}"
                        Padding="12,4" Margin="12,0,12,0"
                        ToolTip="Clear a latched alarm once the leak is resolved (Operator+)."/>
                <Button Content="Zoom All"
                        Command="{Binding ZoomAllCommand}"
                        Padding="12,4" Margin="0,0,12,0"
                        ToolTip="Reset the trend chart to fit all retained data. While zoomed in, the time axis keeps following live data."/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="#444"/>
            </StackPanel>
        </Border>

        <!-- Per-ratio rows -->
        <Border DockPanel.Dock="Top" Background="White"
                BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <ItemsControl ItemsSource="{Binding Ratios}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="12,7"
                                ToolTip="{Binding DetailText}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="115"/>
                                    <ColumnDefinition Width="95"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"
                                              Margin="0,0,8,0"
                                              ToolTip="Include this ratio in leak monitoring."/>
                                    <Ellipse Width="13" Height="13"
                                             Fill="{Binding StateBrush}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                           FontWeight="SemiBold" FontSize="13"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="reference (÷)" FontSize="10" Foreground="#999"/>
                                    <ComboBox ItemsSource="{Binding ReferenceOptions}"
                                              SelectedItem="{Binding SelectedReference}"
                                              ToolTip="Reference line the signal is divided by. Changing it needs a new Golden Run."/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock Text="smoothed ratio" FontSize="10" Foreground="#999"/>
                                    <TextBlock Text="{Binding ValueText}" FontSize="13"/>
                                </StackPanel>

                                <TextBlock Grid.Column="4" Text="{Binding PercentText}"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="{Binding StateBrush}"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="5" VerticalAlignment="Center">
                                    <TextBlock Text="baseline (mean ± σ)" FontSize="10" Foreground="#999"/>
                                    <TextBlock Text="{Binding BaselineText}" FontSize="12"/>
                                </StackPanel>

                                <TextBlock Grid.Column="6" Text="{Binding SlopeText}"
                                           FontSize="12" Foreground="#555"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="7" Text="{Binding StateText}"
                                           FontWeight="Bold"
                                           Foreground="{Binding StateBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Trend chart -->
        <oxy:PlotView Model="{Binding PlotModel}" Background="White"/>
    </DockPanel>
</UserControl>
