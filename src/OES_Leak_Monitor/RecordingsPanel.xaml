<UserControl x:Class="OES_Leak_Monitor.RecordingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#F4F6FA">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin"  Value="0,0,4,0"/>
            <Setter Property="MinWidth" Value="84"/>
        </Style>
        <Style x:Key="ModeButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="MinWidth" Value="64"/>
        </Style>
        <Style x:Key="ActiveModeBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Recordings"
                   FontSize="16" FontWeight="Bold" Foreground="#1F3A66"
                   Margin="6,4,6,8"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#EEF2F7" BorderBrush="#CCC" BorderThickness="1"
                CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
            <DockPanel LastChildFill="True">
                <!-- Right side: filters -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#444"/>
                    <TextBox Width="140" Padding="4,2" Margin="0,0,12,0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filter sessions by date / time / filename substring."/>
                    <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#444"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Margin="0,0,8,0"/>
                    <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#444"/>
                    <DatePicker SelectedDate="{Binding EndDate}"   Margin="0,0,16,0"/>
                    <TextBlock Text="Wavelength (nm):" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#444"/>
                    <!-- LostFocus, not PropertyChanged: updating the float source on every keystroke
                         makes the binding rewrite the text ("777." converts back to "777"), so the
                         decimal point can never be typed. KeyDown commits on Enter. -->
                    <TextBox Width="70" Padding="4,2"
                             Text="{Binding WavelengthNm, UpdateSourceTrigger=LostFocus}"
                             KeyDown="WavelengthBox_KeyDown"
                             ToolTip="Wavelength projected onto the line view; closest header column wins. Press Enter or click away to apply."/>
                </StackPanel>

                <!-- Left side: actions + view mode -->
                <WrapPanel VerticalAlignment="Center">
                    <Button Content="Refresh"             Style="{StaticResource ToolbarButton}"
                            Command="{Binding RefreshCommand}"
                            ToolTip="Re-scan the base directory."/>
                    <Button Content="Open Base"           Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenBaseFolderCommand}"
                            ToolTip="Open the logger's base directory in Windows Explorer."/>
                    <Button Content="Open Folder"         Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenSelectedFolderCommand}"
                            ToolTip="Open the selected session's folder."/>
                    <Button Content="Open File"          Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenOesFileCommand}"
                            ToolTip="Open the session CSV in its default application."/>
                    <Rectangle Width="1" Margin="6,2" Fill="#CCC"/>
                    <TextBlock Text="View:" VerticalAlignment="Center" Margin="2,0,4,0" Foreground="#444"/>

                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource ActiveModeBorder}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLineMode}" Value="True">
                                        <Setter Property="BorderBrush" Value="#1F7A3A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Content="Line"    Style="{StaticResource ModeButton}"
                                Command="{Binding SetLineViewCommand}"/>
                    </Border>
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource ActiveModeBorder}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHeatmapMode}" Value="True">
                                        <Setter Property="BorderBrush" Value="#1F7A3A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Content="Heatmap" Style="{StaticResource ModeButton}"
                                Command="{Binding SetHeatmapViewCommand}"/>
                    </Border>

                    <Rectangle Width="1" Margin="6,2" Fill="#CCC"/>
                    <Button Content="Save PNG"  Style="{StaticResource ToolbarButton}"
                            Command="{Binding SavePngCommand}"
                            ToolTip="Save the currently displayed plot as a PNG file."/>
                    <Button Content="Copy Image" Style="{StaticResource ToolbarButton}"
                            Command="{Binding CopyImageCommand}"
                            ToolTip="Copy the currently displayed plot to the clipboard."/>
                    <Button Content="Clear Compare" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ClearCompareCommand}"
                            ToolTip="Remove the secondary (compare) session."/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Browser | Viewer -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="240"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"   MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
                <DataGrid x:Name="GroupsGrid"
                          ItemsSource="{Binding Groups}"
                          SelectionMode="Extended"
                          SelectionChanged="GroupsGrid_SelectionChanged"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#FAFAFA"
                          EnableRowVirtualization="True"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding DateText}"     Width="90"/>
                        <DataGridTextColumn Header="Time" Binding="{Binding TimeText}"     Width="80"/>
                        <DataGridTextColumn Header="Rot"  Binding="{Binding RotationText}" Width="40"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeText}"     Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="#DDD"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"/>

            <Border Grid.Column="2" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="280" MinHeight="120"/>
                    </Grid.RowDefinitions>

                    <!-- Main plot (line OR heatmap) -->
                    <oxy:PlotView Grid.Row="0" x:Name="MainPlotView"
                                  Model="{Binding ActivePlotModel}"
                                  Controller="{Binding PlotController}"
                                  Background="White"
                                  PreviewMouseLeftButtonDown="MainPlotView_PreviewMouseLeftButtonDown">
                        <oxy:PlotView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Zoom In"   Command="{Binding ZoomInCommand}"  InputGestureText="Wheel ↑"/>
                                <MenuItem Header="Zoom Out"  Command="{Binding ZoomOutCommand}" InputGestureText="Wheel ↓"/>
                                <Separator/>
                                <MenuItem Header="Zoom All"  Command="{Binding ZoomAllCommand}" InputGestureText="A"/>
                                <Separator/>
                                <MenuItem Header="Save PNG…"   Command="{Binding SavePngCommand}"/>
                                <MenuItem Header="Copy Image"  Command="{Binding CopyImageCommand}"/>
                                <Separator/>
                                <MenuItem Header="Open File"           Command="{Binding OpenOesFileCommand}"/>
                                <MenuItem Header="Open Session Folder" Command="{Binding OpenSelectedFolderCommand}"/>
                            </ContextMenu>
                        </oxy:PlotView.ContextMenu>
                    </oxy:PlotView>

                    <GridSplitter Grid.Row="1"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Background="#DDD"
                                  ResizeBehavior="PreviousAndNext"
                                  ResizeDirection="Rows"/>

                    <!-- Bottom: frame spectrum | notes -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="280" MinWidth="160"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#EEE" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <oxy:PlotView Grid.Row="0" x:Name="FramePlotView"
                                              Model="{Binding FrameSpectrumModel}"
                                              Controller="{Binding FrameController}"
                                              Background="White">
                                    <oxy:PlotView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Clear" Command="{Binding ClearFrameCommand}"/>
                                        </ContextMenu>
                                    </oxy:PlotView.ContextMenu>
                                </oxy:PlotView>
                                <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#EEE"
                                        BorderThickness="0,1,0,0" Padding="8,4">
                                    <TextBlock Text="{Binding FrameInfoText}" Foreground="#666" FontSize="11"/>
                                </Border>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                      Background="#DDD"
                                      ResizeBehavior="PreviousAndNext"
                                      ResizeDirection="Columns"/>

                        <Border Grid.Column="2" Background="#FAFAFA" BorderBrush="#EEE"
                                BorderThickness="1,1,0,0" Padding="8,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Notes" FontWeight="SemiBold" Foreground="#1F3A66"/>
                                <TextBox Grid.Row="1"
                                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas, monospace"
                                         FontSize="11"
                                         Margin="0,4,0,4"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Button Content="Save Notes" Padding="10,4"
                                            Command="{Binding SaveNotesCommand}"
                                            ToolTip="Persist notes to a sidecar .notes.txt next to the session's CSV files."/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status / meta strip -->
        <Border Grid.Row="3" Background="#EEF2F7" BorderBrush="#CCC" BorderThickness="1"
                CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status:" FontWeight="Bold" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="#444"/>
                    <TextBlock Text="  ·  Base:" FontWeight="Bold" Margin="16,0,6,0"/>
                    <TextBlock Text="{Binding EffectiveBaseDirectory}"
                               FontFamily="Consolas, monospace"
                               ToolTip="{Binding EffectiveBaseDirectory}"/>
                </StackPanel>
                <TextBlock Text="{Binding WavelengthInfoText}" Foreground="#444" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding MetaText}" Foreground="#666"
                           FontFamily="Consolas, monospace" FontSize="11"
                           TextWrapping="NoWrap" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
