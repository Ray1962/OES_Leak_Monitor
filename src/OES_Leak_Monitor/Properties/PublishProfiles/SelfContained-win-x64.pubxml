<?xml version="1.0" encoding="utf-8"?>
<!--
  Standalone publish profile: produces a single self-contained .exe that bundles
  the .NET 8 runtime — the target PC needs NO .NET install.

  Build it from Visual Studio (right-click project > Publish > this profile) or:
    dotnet publish src\OES_Leak_Monitor\OES_Leak_Monitor.csproj -p:PublishProfile=SelfContained-win-x64

  Output lands in src\OES_Leak_Monitor\bin\Publish\win-x64\. The .exe bundles
  all managed code plus the .NET 8 runtime, but native DLLs are NOT bundled —
  they sit loose next to the .exe and must ship with it:
    OES_Leak_Monitor.exe                       app + bundled .NET 8 runtime
    wpfgfx_cor3.dll, PresentationNative_cor3.dll,
    D3DCompiler_47_cor3.dll, PenImc_cor3.dll,
    vcruntime140_cor3.dll                      WPF native runtime DLLs
    UserApplication.dll, SiUSBXp.dll           native OES / USB DLLs

  Why native DLLs stay loose: WPF native libraries cannot be embedded, and
  Aqst.OesSpectrometer's DllResolver only searches the app base directory, so
  UserApplication.dll / SiUSBXp.dll must be physical files next to the .exe.
  .NET leaves native libraries beside a single-file exe by default
  (IncludeNativeLibrariesForSelfExtract is left false on purpose) and the
  FlattenOesNativeDlls target backstops the OES DLL copy. Ship the whole folder.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishDir>bin\Publish\win-x64\</PublishDir>

    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>

    <!-- WPF relies on XAML reflection; trimming is unsafe here. -->
    <PublishTrimmed>false</PublishTrimmed>

    <!-- Fold debug symbols into the exe so no loose .pdb ships. -->
    <DebugType>embedded</DebugType>
  </PropertyGroup>
</Project>
